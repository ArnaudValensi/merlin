# Dashboard auth (required)
DASHBOARD_USER=admin
DASHBOARD_PASS=your-password-here

# Cloudflare Tunnel (HTTPS access)
# TUNNEL_ENABLED=true          # Set to false to disable tunnel
# TUNNEL_TOKEN=                # Cloudflare Tunnel token for named tunnel (stable URL)
# TUNNEL_HOSTNAME=             # Custom hostname (e.g., merlin.example.com)
